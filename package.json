{
  "name": "pi-claude-style-scroll",
  "version": "0.3.3",
  "description": "Pi extension for a Claude Code-style pinned composer: scroll message history while typing.",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "index.ts",
    "src",
    "config/config.example.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "npx --yes -p typescript@5.7.3 tsc -p tsconfig.json",
    "build": "npx --yes -p typescript@5.7.3 tsc -p tsconfig.json --noCheck",
    "lint": "npm run typecheck",
    "test": "node --test test/*.test.cjs",
    "check": "npm run lint && npm run test && npm run build",
    "package:dry-run": "npm pack --dry-run",
    "postinstall": "node -e \"const fs=require('fs'),cp=require('child_process'),p=require('path');const cwd=process.cwd();const normalized=cwd.split(p.sep).join('/');if(!normalized.includes('/.pi/agent/extensions/'))process.exit(0);const s=p.resolve(cwd,'../../scripts/patch-vulnerable-deps.mjs');if(!fs.existsSync(s))process.exit(0);const r=cp.spawnSync(process.execPath,[s,'--target',cwd,'--quiet'],{stdio:'inherit'});process.exit(r.status||0)\""
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "pi-coding-agent",
    "pi-tui",
    "coding-agent",
    "chat-input",
    "terminal",
    "alternate-screen",
    "footer",
    "claude-style-scroll",
    "claude-code-style",
    "scroll-while-typing",
    "pinned-composer",
    "sticky-scroll"
  ],
  "author": "EmilioAK (https://github.com/EmilioAK)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EmilioAK/pi-claude-style-scroll.git"
  },
  "bugs": {
    "url": "https://github.com/EmilioAK/pi-claude-style-scroll/issues"
  },
  "homepage": "https://github.com/EmilioAK/pi-claude-style-scroll#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "video": "https://raw.githubusercontent.com/EmilioAK/pi-claude-style-scroll/main/assets/demo.mp4"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0 || ^0.75.0 || ^0.77.0 || ^0.78.0 || ^0.79.0 || ^0.80.0",
    "@earendil-works/pi-tui": "^0.74.0 || ^0.75.0 || ^0.77.0 || ^0.78.0 || ^0.79.0 || ^0.80.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@earendil-works/pi-tui": "^0.80.3",
    "jiti": "^2.7.0"
  },
  "overrides": {
    "protobufjs": "7.6.3",
    "ws": "8.21.0"
  },
  "contributors": [
    "MasuRii (https://github.com/MasuRii)"
  ]
}
